<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My website</title>

</head>
<style>
    *{
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    nav ul{
        padding: 20px;
        gap: 20px;
        list-style: none;
        margin-top: 10px;

    }
/* Table */
    table{
        width: 300px;
        border-collapse: collapse;
        
    }
    td,th{
        padding: 20px;
        border: 1px solid;
        text-align: center;
    }
   
/* Body */
    body{
        font-family: Arial, Helvetica, sans-serif;
        background-color: rgb(160, 249, 71);
        padding: 20px;
        text-align: center;
    }
    .grid-container{
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 20px;
        margin-top: 20px;
    }
    .box{
        background: #ccc;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 1)

    }
/* form */
    form{
        display: grid;
        gap: 15px;
        margin-top:20px;
    }
    input{
        padding: 10px;
        border: 1px solid #ccc;
        margin: 10px;
        border: #ccc;
    }
    button{
        padding: 10px;
        border: none;
        background-color: #0077ff;
        color: #ccc;
        cursor: pointer;
        transition: background 0.3s ease;
    }
    button:hover{
        background: #c21212;
    }
    img{
        border: 1px solid rgb(13, 3, 3);
       
    }
    @media (max-width:600px){
        .grid-container{
            grid-template-columns: 1fr;
            background-color: rgb(200, 200, 26);
        }
    }

   

</style>


<body>

<!-- Header and main -->
   <header>
    <h1>My first exam</h1>
        <nav>
            <ul>
                <li><a href="Google.com">Google</a>
                <li><a href="Youtube.com">Youtube</a></li>
            </ul>
        </nav>
   </header>

   <main>
    <div class="grid-container">
        <div class="box">
            <h2>Card 1</h2>
            <p>Test</p>
        </div>

        <div class="box">
            <h2>Card 2</h2>
            <p>Test</p>
        </div>    
    </div>
    </main>


   <!-- table -->
   <table>
   <caption>Table</caption>
    <tr> 
        <th>Гарчиг</th>
        <th>Гарчиг</th>
    </tr>
    <tr>
        <td>Тест</td>
        <td>Онол</td>
    </tr>
    <tr>
        <td>Сайн уу</td>
        <td>Муу юу</td>
    </tr> 
   </table>

   <!-- form -->
    <label for="#"><textarea name="noname" id="textarea"></textarea></label>
    <br>
    <span>Gender:</span>
        <br>
        <input id="male" name="gender" type="radio">
        <label for="male">Male</label>
        <input id="female" name="gender" type="radio">
        <label for="female">Female</label>
        <br>
    <input type="email" placeholder="Enter your email" required>  
    <br>
    <button type="submit">Submit</button> 


 <!--img-->
    <h1>Rainy day</h1>
    <img src="rain.jpg" height="90%" width="90%">
 
</body>
</html>
